{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JohnnWi/homelab-project/connectors/schema/service-connector.schema.json",
  "title": "Homelab Service Connector",
  "description": "Declarative contract for a self-hosted service integration. The mobile apps can use this metadata to scaffold connection forms, read-only dashboards, metrics, and safe actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "displayName",
    "category",
    "auth",
    "baseUrl",
    "capabilities",
    "endpoints",
    "platforms"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "displayName": {
      "type": "string",
      "minLength": 2
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "infrastructure",
        "networking",
        "media",
        "observability",
        "developer-tools",
        "gaming",
        "utility"
      ]
    },
    "icon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selfhstSlug": {
          "type": "string"
        },
        "assetName": {
          "type": "string"
        }
      }
    },
    "baseUrl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["placeholder"],
      "properties": {
        "placeholder": {
          "type": "string",
          "examples": ["https://portainer.example.com"]
        },
        "defaultPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "allowSelfSignedTls": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "api_key", "bearer_token", "basic", "session_cookie", "custom"]
        },
        "header": {
          "type": "string"
        },
        "queryParam": {
          "type": "string"
        },
        "credentialFields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "secret"],
            "properties": {
              "key": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
              },
              "label": {
                "type": "string"
              },
              "secret": {
                "type": "boolean"
              },
              "required": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read", "write", "destructiveActions"],
      "properties": {
        "read": {
          "type": "boolean"
        },
        "write": {
          "type": "boolean"
        },
        "destructiveActions": {
          "type": "boolean"
        }
      }
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "method", "path", "purpose"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
          },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string"
          },
          "responseRoot": {
            "type": "string"
          },
          "requiresConfirmation": {
            "type": "boolean",
            "default": false
          },
          "risk": {
            "type": "string",
            "enum": ["read", "safe-write", "destructive"]
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "sourceEndpoint", "jsonPath"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
          },
          "label": {
            "type": "string"
          },
          "sourceEndpoint": {
            "type": "string"
          },
          "jsonPath": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": ["number", "percent", "bytes", "duration", "boolean", "string"]
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "endpointId", "risk"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
          },
          "label": {
            "type": "string"
          },
          "endpointId": {
            "type": "string"
          },
          "risk": {
            "type": "string",
            "enum": ["safe-write", "destructive"]
          },
          "confirmationText": {
            "type": "string"
          }
        }
      }
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ios", "android"],
      "properties": {
        "ios": {
          "type": "string",
          "enum": ["planned", "supported", "partial", "unsupported"]
        },
        "android": {
          "type": "string",
          "enum": ["planned", "supported", "partial", "unsupported"]
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "testedVersions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "securityNotes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
